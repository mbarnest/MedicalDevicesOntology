#################################################################
#    Annotations
#################################################################

<http://purl.org/dc/terms/description> rdfs:comment "A descriptive text explaining the resource"@en ,
                                                    "http://purl.org/dc/terms/" ;
                                       rdfs:label "Description"@en .


<http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIII> rdfs:comment "High-risk medical devices, typically those that support or sustain life, are implanted, or present a potential significant risk of illness or injury."@en ;
                                                                              rdfs:label "Class III"@en .


<http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/IVDR> rdfs:comment "Regulation (EU) 2017/746 of the European Parliament and of the Council on in vitro diagnostic medical devices and repealing Directive 98/79/EC and Commission Decision 2010/227/EU."@en ;
                                                                          rdfs:label "IVDR (In Vitro Diagnostic Medical Devices Regulation)"@en .


<http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ImplantableActiveDevice> rdfs:comment "Device that can be inserted inside the human body."@en ;
                                                                                             rdfs:label "Implantable Active Device"@en .


<http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/InjuryRisk> rdfs:comment "Risk of physical trauma or damage to the human body associated with device operation or failure."@en ;
                                                                                rdfs:label "Injury Risk"@en .


<http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/MDR> rdfs:comment "Regulation (EU) 2017/745 of the European Parliament and of the Council on medical devices, amending Directive 2001/83/EC, Regulation (EC) No 178/2002 and Regulation (EC) No 1223/2009."@en ;
                                                                         rdfs:label "MDR (Medical Device Regulation)"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassC>
                <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassD>
                <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIII>
                <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIIa>
                <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIIb>
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/InSituCorrection>
                <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/Recall>
                <http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/UserNotice>
              )
] .


#################################################################
#    Rules
