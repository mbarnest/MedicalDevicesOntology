}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "This ontology includes medical devices, catalogued within the regulatory frameworks European MDR (EU 2017/745) and IVDR (EU 2017/746). Its purpose is to represent medical devices, their manufacturers, risks, incidents and corrective actions."
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Medical Devices Ontology"
  }, {
    "@language" : "en",
    "@value" : "Miguel Ángel Barnés Torrente"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Ontology for incidents, risk and actions related to medical devices."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Medical Devices Ontology"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ActiveDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A device that relies on a source of electrical energy."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Active Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/Device"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ActiveImplant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An active device that is also implantable."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Active Implant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/Device"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/CibersecurityRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Risk associated with vulnerabilities in the network or software of a medical device that could lead to unauthorized access or malfunction."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cybersecurity Risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/Risk"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassC",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High individual risk and/or moderate public health risk in vitro diagnostic devices, such as those used for genetic testing or cancer screening."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class C"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/RiskClass"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassD",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High individual risk and high public health risk in vitro diagnostic devices, typically used for detecting life-threatening infectious diseases in blood supply."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class D"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/RiskClass"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIII",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIII"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "High-risk medical devices, typically those that support or sustain life, are implanted, or present a potential significant risk of illness or injury."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class III"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/RiskClass"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIIa",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Medium-risk medical devices, including some diagnostic and therapeutic tools, that require a moderate level of monitoring and certification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class IIa"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/RiskClass"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIIb",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Medium-high risk medical devices, often including more complex implants or long-term invasive devices, subject to stricter assessment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Class IIb"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/RiskClass"
