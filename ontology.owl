    <rdf:Description rdf:about="http://purl.org/dc/terms/description">
        <rdfs:comment xml:lang="en">A descriptive text explaining the resource</rdfs:comment>
        <rdfs:comment>http://purl.org/dc/terms/</rdfs:comment>
        <rdfs:label xml:lang="en">Description</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ClassIII">
        <rdfs:comment xml:lang="en">High-risk medical devices, typically those that support or sustain life, are implanted, or present a potential significant risk of illness or injury.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/IVDR">
        <rdfs:comment xml:lang="en">Regulation (EU) 2017/746 of the European Parliament and of the Council on in vitro diagnostic medical devices and repealing Directive 98/79/EC and Commission Decision 2010/227/EU.</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR (In Vitro Diagnostic Medical Devices Regulation)</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/ImplantableActiveDevice">
        <rdfs:comment xml:lang="en">Device that can be inserted inside the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/InjuryRisk">
        <rdfs:comment xml:lang="en">Risk of physical trauma or damage to the human body associated with device operation or failure.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/migue/ontologies/MedicalDevicesOntology/MDR">
        <rdfs:comment xml:lang="en">Regulation (EU) 2017/745 of the European Parliament and of the Council on medical devices, amending Directive 2001/83/EC, Regulation (EC) No 178/2002 and Regulation (EC) No 1223/2009.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR (Medical Device Regulation)</rdfs:label>
    </rdf:Description>
    


